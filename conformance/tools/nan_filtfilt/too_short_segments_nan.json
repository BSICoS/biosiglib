{
  "$schema": "../../../schemas/conformance-case.schema.json",
  "id": "tools.nan_filtfilt.too_short_segments_nan",
  "specification_id": "tools.nan_filtfilt",
  "description": "Candidate finite segments too short for MATLAB-style filtfilt produce NaN output over those segments.",
  "inputs": [
    {
      "id": "numerator_coefficients",
      "value": [
        0.5,
        0.5
      ]
    },
    {
      "id": "denominator_coefficients",
      "value": [
        1
      ]
    },
    {
      "id": "signal",
      "fixture_id": "tools.synthetic.nan_filtering_cases",
      "file_role": "short_segments_case_table",
      "column": "x_short_segments"
    }
  ],
  "parameters": {
    "max_gap": 1
  },
  "expected_outputs": [
    {
      "id": "filtered_signal",
      "fixture_id": "tools.synthetic.nan_filtering_cases",
      "file_role": "short_segments_case_table",
      "column": "nan_filtfilt_too_short_segments",
      "absolute_tolerance": 0
    }
  ],
  "nan_equal": true,
  "oracle": {
    "type": "analytical",
    "description": "filter_order = max(length([0.5, 0.5]) - 1, length([1]) - 1) = 1, and each finite segment has length one, which is not greater than 3 * filter_order."
  }
}
