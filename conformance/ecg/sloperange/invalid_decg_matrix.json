{
  "$schema": "../../../schemas/conformance-case.schema.json",
  "id": "ecg.sloperange.invalid_decg_matrix",
  "specification_id": "ecg.sloperange",
  "description": "Reject a matrix-shaped derivative ECG input.",
  "inputs": [
    {
      "id": "decg",
      "value": [
        [
          0,
          1
        ],
        [
          2,
          3
        ]
      ]
    },
    {
      "id": "r_peak_times",
      "value": [
        0.1
      ]
    },
    {
      "id": "sampling_frequency",
      "value": 100
    }
  ],
  "parameters": {},
  "expected_error": {
    "category": "invalid_shape",
    "description": "decg must be a one-dimensional vector."
  },
  "oracle": {
    "type": "analytical",
    "description": "This expected-error case follows directly from the normative decg shape."
  }
}
