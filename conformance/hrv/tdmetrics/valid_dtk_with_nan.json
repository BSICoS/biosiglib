{
  "$schema": "../../../schemas/conformance-case.schema.json",
  "id": "hrv.tdmetrics.valid_dtk_with_nan",
  "specification_id": "hrv.tdmetrics",
  "description": "Compute time-domain HRV metrics from an interval vector dtk containing NaN markers that are omitted from all calculations.",
  "inputs": [
    {
      "id": "dtk",
      "fixture_id": "ecg.medicom_mtd.r_wave_timing",
      "file_role": "beat_timing_table",
      "column": "dtk"
    }
  ],
  "parameters": {},
  "expected_outputs": [
    {"id": "mhr", "value": 85.0470840237643, "absolute_tolerance": 1e-10},
    {"id": "sdnn", "value": 40.260126771653375, "absolute_tolerance": 1e-10},
    {"id": "sdsd", "value": 18.621407372538773, "absolute_tolerance": 1e-10},
    {"id": "rmssd", "value": 18.553175731756973, "absolute_tolerance": 1e-10},
    {"id": "pnn50", "value": 1.4705882352941178, "absolute_tolerance": 1e-10}
  ],
  "nan_equal": true,
  "oracle": {
    "type": "analytical",
    "description": "Expected values are calculated directly from the fixture dtk column after omitting missing-value markers."
  }
}
