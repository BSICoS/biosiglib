{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biosiglib conformance case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "id",
    "specification_id",
    "description",
    "inputs",
    "parameters",
    "expected_outputs",
    "nan_equal",
    "oracle"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "specification_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/input_mapping"
      }
    },
    "parameters": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "integer"
          },
          {
            "type": "boolean"
          },
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/expected_output"
      }
    },
    "nan_equal": {
      "type": "boolean"
    },
    "oracle": {
      "$ref": "#/$defs/oracle"
    }
  },
  "$defs": {
    "input_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "fixture_id",
        "file_role",
        "column"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "fixture_id": {
          "type": "string",
          "minLength": 1
        },
        "file_role": {
          "type": "string",
          "minLength": 1
        },
        "column": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "value",
        "absolute_tolerance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "const": "NaN"
            }
          ]
        },
        "absolute_tolerance": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "oracle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "description"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "analytical",
            "biosigmat",
            "external_annotation",
            "published_reference",
            "manual_review"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "implementation_version": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        },
        "reference_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
