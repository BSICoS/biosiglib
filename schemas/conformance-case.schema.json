{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biosiglib conformance case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "id",
    "specification_id",
    "description",
    "inputs",
    "parameters",
    "oracle"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "specification_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/input_mapping"
      }
    },
    "parameters": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/case_value"
      }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/expected_output"
      }
    },
    "expected_error": {
      "$ref": "#/$defs/expected_error"
    },
    "nan_equal": {
      "type": "boolean"
    },
    "oracle": {
      "$ref": "#/$defs/oracle"
    }
  },
  "oneOf": [
    {
      "required": [
        "expected_outputs",
        "nan_equal"
      ],
      "not": {
        "required": [
          "expected_error"
        ]
      }
    },
    {
      "required": [
        "expected_error"
      ],
      "not": {
        "anyOf": [
          {
            "required": [
              "expected_outputs"
            ]
          },
          {
            "required": [
              "nan_equal"
            ]
          }
        ]
      }
    }
  ],
  "$defs": {
    "case_value": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/case_value"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/case_value"
          }
        }
      ]
    },
    "input_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "fixture_id": {
          "type": "string",
          "minLength": 1
        },
        "file_role": {
          "type": "string",
          "minLength": 1
        },
        "column": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "$ref": "#/$defs/case_value"
        }
      },
      "oneOf": [
        {
          "required": [
            "fixture_id",
            "file_role",
            "column"
          ],
          "not": {
            "required": [
              "value"
            ]
          }
        },
        {
          "required": [
            "value"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "fixture_id"
                ]
              },
              {
                "required": [
                  "file_role"
                ]
              },
              {
                "required": [
                  "column"
                ]
              }
            ]
          }
        }
      ]
    },
    "expected_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "absolute_tolerance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "const": "NaN"
            }
          ]
        },
        "fixture_id": {
          "type": "string",
          "minLength": 1
        },
        "file_role": {
          "type": "string",
          "minLength": 1
        },
        "column": {
          "type": "string",
          "minLength": 1
        },
        "absolute_tolerance": {
          "type": "number",
          "minimum": 0
        }
      },
      "oneOf": [
        {
          "required": [
            "value"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "fixture_id"
                ]
              },
              {
                "required": [
                  "file_role"
                ]
              },
              {
                "required": [
                  "column"
                ]
              }
            ]
          }
        },
        {
          "required": [
            "fixture_id",
            "file_role",
            "column"
          ],
          "not": {
            "required": [
              "value"
            ]
          }
        }
      ]
    },
    "expected_error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category"
      ],
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "invalid_type",
            "invalid_shape",
            "invalid_value",
            "insufficient_data"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "oracle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "description"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "analytical",
            "biosigmat",
            "external_annotation",
            "published_reference",
            "manual_review"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "implementation_version": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        },
        "reference_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
