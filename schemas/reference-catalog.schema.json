{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biosiglib reference catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "references"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "title",
          "authors",
          "year"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "journal_article",
              "conference_paper",
              "book",
              "book_chapter",
              "standard",
              "other"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "authors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "oneOf": [
                {
                  "$ref": "#/$defs/person_author"
                },
                {
                  "$ref": "#/$defs/organization_author"
                }
              ]
            }
          },
          "year": {
            "type": "integer"
          },
          "journal": {
            "type": "string"
          },
          "volume": {
            "type": "string"
          },
          "issue": {
            "type": "string"
          },
          "pages": {
            "type": "string"
          },
          "article_number": {
            "type": "string"
          },
          "doi": {
            "type": "string"
          },
          "pmid": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  },
  "$defs": {
    "person_author": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "family_name",
        "given_names"
      ],
      "properties": {
        "type": {
          "const": "person"
        },
        "family_name": {
          "type": "string",
          "minLength": 1
        },
        "given_names": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "organization_author": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name"
      ],
      "properties": {
        "type": {
          "const": "organization"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
